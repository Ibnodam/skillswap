{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Urls": "http://localhost:5000",
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "meetings": {
        "ClusterId": "meetings-cluster",
        "Match": {
          "Path": "/api/meetings/{**catch-all}"
        }
      },
      "reviews": {
        "ClusterId": "reviews-cluster",
        "Match": {
          "Path": "/api/reviews/{**catch-all}"
        }
      },
      "messages-api": {
        "ClusterId": "messages-cluster",
        "Match": {
          "Path": "/api/messages/{**catch-all}"
        }
      },
      "chat-hub": {
        "ClusterId": "messages-cluster",
        "Match": {
          "Path": "/hubs/chat/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "users": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "meetings-cluster": {
        "Destinations": {
          "meetings": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "reviews-cluster": {
        "Destinations": {
          "reviews": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "messages-cluster": {
        "Destinations": {
          "messages": {
            "Address": "http://localhost:5005/"
          }
        }
      }
    }
  }
}



